# Crane Cash Cockpit (Next.js / Vercel) — copy to .env.local and fill in.
# Set these same values in Vercel → Project Settings → Environment Variables.

# Password you type at the gate
APP_PASSWORD=

# HMAC signing secret for the session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Actual bridge service (runs on the Actual host — see actual-bridge/).
# The Next app talks ONLY to the bridge now; the @actual-app/api SDK and the
# ACTUAL_* vars moved to the bridge's own environment.
BRIDGE_URL=https://cranecashapp.com:5007
# Shared bearer token — MUST match BRIDGE_BEARER_TOKEN on the bridge.
# Generate with: openssl rand -hex 32
BRIDGE_BEARER_TOKEN=
