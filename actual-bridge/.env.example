# actual-bridge environment.
# In production these are set in the docker-compose service on the Hetzner host,
# NOT committed. Copy to .env for local `docker run --env-file` testing.

# Port the bridge listens on.
PORT=5007

# Shared bearer token clients must present. MUST match the Next app's
# BRIDGE_BEARER_TOKEN. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_BEARER_TOKEN=

# Actual Budget server — public HTTPS endpoint (same host, valid cert).
ACTUAL_SERVER_URL=https://cranecashapp.com:5006
ACTUAL_PASSWORD=
# Budget Sync ID — Actual: Settings → Advanced → "Sync ID"
ACTUAL_SYNC_ID=

# Where the SDK caches the downloaded budget (persistent docker volume on prod).
DATA_DIR=/data

# Finnhub API key for live quotes, company names, 52-week range, and analyst
# recommendations. Free tier at https://finnhub.io. Without it, /prices and
# /signals return 502 and the dashboard falls back to cost-basis only.
FINNHUB_API_KEY=

# Twelve Data API key — used ONLY for the 50/200-day moving averages and RSI(14)
# that Finnhub's free tier can't provide (its candle endpoint is premium). Free
# tier at https://twelvedata.com (8 calls/min, 800/day). Without it, MA/RSI stay
# null and the rest of /signals is unaffected.
TWELVEDATA_API_KEY=

# Financial Modeling Prep API key — used ONLY for the analyst price-target
# consensus (Finnhub's target endpoint is premium). Free tier at
# https://financialmodelingprep.com. Without it (or if FMP free gates targets),
# the priceTarget field stays null and the entry rating still works.
FMP_API_KEY=

# TLS — production terminates HTTPS in-process using the host's letsencrypt cert
# (mounted read-only). For local testing without a cert, set TLS_DISABLED=1.
# TLS_DISABLED=1
TLS_CERT=/etc/letsencrypt/live/cranecashapp.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/cranecashapp.com/privkey.pem
